# GitHub Actions
/.github/

# Node modules
node_modules/

# Build outputs
dist/
dist-github/
build/
*.js.map
*.d.ts.map

# Test outputs
test-output/
coverage/

# Agent state (local machine-specific)
.cursor/autonomous-memory/
.cursor/agent-state/
.cursor/.session-state.json

# Skill cache (regenerates on install)
.cursor/skills/
.cursor/.skill-cache/
.skill-cache/

# Environment files
.env
.env.local
.env.*.local
*.env

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.#*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*.bak
*.orig

# Cursor plugin artifacts (rebuilt by plugin:publish)
.cursor/plugins/
.cursor/cache/

# Test temp directories
Temp/
tmp/

# Audit log (regenerated by security subsystem)
audit.log
audit.*.log

# HardenedAuditLog Merkle chain snapshots
*.audit.chain

# Skill test artifacts (generated during testing)
skills/test-skill-*/

# .vscode/task artifacts should be ignored BUT tasks.json should be committed
!.vscode/tasks.json
!.vscode/settings.json

# Runtime bundles (built by plugin:build)
runtime/lib/*.bundle.mjs
runtime/lib/*.bundle.mjs.map
runtime/bin/
runtime/tmp/

# Debug/temp files
_*.cjs
_*.js
debug-*
*.debug.*

# Orphan examples
dist-github/mautoma-agent/runtime/lib/*.bundle.mjs
dist-github/mautoma-agent/runtime/lib/*.bundle.mjs.map

# Local hooks/scripts (test artifacts)
hooks/*.bak
hooks/*.tmp
hooks/*.debug.*

# tsbuildinfo (TypeScript incremental cache)
*.tsbuildinfo

# Plugin caches (regenerated on install)
.plugin-cache/
.cache/
.eslintcache

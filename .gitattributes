# Force LF for all text files in this repo
# Prevents Cursor strict JSON parser from failing on CRLF

* text=auto eol=lf

# Critical: explicit LF for JSON files
*.json text eol=lf
*.jsonc text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.ts text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary

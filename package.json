{
  "name": "mautoma-agent",
  "version": "1.0.1",
  "description": "Mautoma agent runtime — CapabilityRouter, AutoApply engine, AI file cleaner. Both a Cursor plugin (see .cursor-plugin/plugin.json) and a standalone npm package.",
  "main": "index.ts",
  "type": "commonjs",
  "scripts": {
    "start": "tsx auto-apply/smart_runner.ts",
    "start:daemon": "tsx auto-apply/smart_runner.ts --daemon",
    "start:status": "tsx auto-apply/smart_runner.ts --status",
    "agent": "tsx agent_cli.ts",
    "agent:status": "tsx agent_cli.ts --status",
    "agent:continuous": "tsx agent_cli.ts --continuous",
    "router": "tsx scripts/capability-router-cli.ts",
    "cleanup": "tsx file-cleaner/cli.ts",
    "cleanup:dry-run": "tsx file-cleaner/cli.ts --dry-run",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "test": "npm run typecheck"
  },
  "bin": {
    "capability-router": "./scripts/capability-router-cli.js",
    "mautoma-agent": "./scripts/agent-cli.js"
  },
  "keywords": [
    "cursor",
    "cursor-ide",
    "cursor-plugin",
    "ai-agent",
    "autonomous-agent",
    "automation",
    "capability-router",
    "dispute-tournament",
    "elo-rating",
    "self-evolving",
    "typescript"
  ],
  "author": {
    "name": "huyhieu2k5"
  },
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/huyhieu2k5/mautoma-agent"
  },
  "bugs": {
    "url": "https://github.com/huyhieu2k5/mautoma-agent/issues"
  },
  "homepage": "https://github.com/huyhieu2k5/mautoma-agent#readme",
  "files": [
    "auto-apply/",
    "file-cleaner/",
    "capability-router/",
    "skill-manager/",
    "evolution/",
    "task-planner/",
    "executor/",
    "verification/",
    "memory-store/",
    "error-recovery/",
    "codegraph/",
    "evaluation/",
    "security/",
    "computer-control/",
    "agent-orchestration/",
    "scripts/",
    "skills/",
    "rules/",
    "agents/",
    "index.ts",
    "agent_cli.ts",
    "app-manifest.json",
    ".cursor-plugin/",
    ".cursor/",
    ".eslintrc.json",
    "tsconfig.json"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jsonc-parser": "^3.3.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

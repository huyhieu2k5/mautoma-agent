{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mautoma-agent.local/schemas/app-manifest.schema.json",
  "title": "Mautoma Agent App Manifest",
  "description": "Schema for app-manifest.json — the runtime/npm side manifest. NOT read by Cursor.",
  "type": "object",
  "required": ["name", "version", "runtime"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9.-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([.-].+)?$"
    },
    "description": { "type": "string" },
    "author": {
      "oneOf": [
        { "type": "string" },
        { "type": "object" }
      ]
    },
    "license": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "repository": { "type": "string" },
    "capabilityAxes": {
      "type": "object",
      "properties": {
        "axes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "scripts": { "type": "object" },
    "runtime": {
      "type": "object",
      "required": ["engine", "minVersion", "entry"],
      "properties": {
        "engine": { "type": "string" },
        "minVersion": { "type": "string" },
        "entry": { "type": "string" },
        "packageManager": { "type": "string" },
        "npmPackage": { "type": "string" }
      }
    },
    "security": { "type": "object" },
    "dependencies": { "type": "object" }
  }
}